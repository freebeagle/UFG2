{
  "alias": "UFGraphFR",
  "dataset": "mcp",
  "mcp_data_dir": "data/mcp_user_split",
  "mcp_user_json": "data/mcp_prepare/user_side/raw/filtered_clients.json",
  "use_jointembedding": true,
  "use_item_attribute": true,
  "item_attribute_set": "A",
  "pre_model": "HF_LOCAL",
  "hf_embedding_model": "D:\\models\\all-MiniLM-L6-v2",
  "embed_dim": 384,
  "latent_dim": 32,
  "use_transfermer": false,
  "dp": 0.0,
  "num_round": 50,
  "clients_sample_ratio": 0.1,
  "local_epoch": 1,
  "neighborhood_size": 5,
  "neighborhood_threshold": 1.0,
  "mp_layers": 1,
  "similarity_metric": "cosine",
  "lr": 0.01,
  "lr_eta": 1,
  "batch_size": 128,
  "reg": 1.0,
  "num_negative": 4
}
